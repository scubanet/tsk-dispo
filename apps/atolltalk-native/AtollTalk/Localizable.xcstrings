    "Abos konnten nicht geladen werden. Prüfe die Verbindung — oder die Produkte sind in App Store Connect noch nicht freigegeben." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subscriptions could not be loaded. Check your connection — or the products are not yet approved in App Store Connect."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudieron cargar las suscripciones. Comprueba la conexión — o los productos aún no están aprobados en App Store Connect."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de charger les abonnements. Vérifie ta connexion — ou les produits ne sont pas encore validés dans App Store Connect."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossibile caricare gli abbonamenti. Controlla la connessione — oppure i prodotti non sono ancora approvati in App Store Connect."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не вдалося завантажити підписки. Перевірте з'єднання — або продукти ще не схвалені в App Store Connect."
          }
        }
      }
    },
